Table dim_year {
  year_id int [pk]
  year int [not null]
}

Table dim_municipality {
  municipality_id varchar(32) [pk]
  municipality_name varchar [not null]
}

Table fact_economic_shock_exposure {
  year_id int [not null]
  municipality_id varchar(32) [not null]
  bankruptcy_rate_cv_3y decimal(10,4)
  employee_impact_cv_3y decimal(10,4)
  business_churn_cv_3y decimal(10,4)
  personnel_cv_3y decimal(10,4)
  demographic_stability_cv_3y decimal(10,4)
  shock_exposure_composite decimal(10,4)
  shock_resilience_ntile int
  shock_resilience_class varchar
  bankruptcy_rate_per_1000 decimal(10,2)
  establishments_count int
  population int
  deaths int
  death_rate_per_1000 decimal(10,2)
  establishments_yoy_pct decimal(10,4)
  population_change_pct decimal(10,4)

  indexes {
    (year_id, municipality_id) [unique]
  }

  Note: '''
  Grain: one row per year per municipality.
  Five rolling 3-year coefficient of variation (CV) measures capture
  volatility across bankruptcy, business, and demographic dimensions.
  shock_exposure_composite is a weighted sum (0.35 bankruptcy + 0.25 employee
  impact + 0.20 business churn + 0.10 personnel + 0.10 demographic).
  CV measures are NULL when fewer than 3 consecutive years of data exist.
  '''
}

Ref: fact_economic_shock_exposure.year_id > dim_year.year_id
Ref: fact_economic_shock_exposure.municipality_id > dim_municipality.municipality_id
