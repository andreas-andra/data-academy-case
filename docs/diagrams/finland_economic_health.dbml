Table dim_year {
  year_id int [pk]
  year int [not null]
}

Table fact_finland_economic_health {
  year int
  year_id int [not null]
  total_bankruptcies_enterprises int
  total_bankruptcies_employees int
  total_establishments int
  total_personnel_staff_years int
  total_population int
  total_deaths int
  death_rate_per_1000 decimal(10,2)
  new_establishments_yoy int
  establishment_growth_pct decimal(10,2)
  bankruptcy_growth_pct decimal(10,2)
}

Ref: fact_finland_economic_health.year_id > dim_year.year_id

Index fact_finland_economic_health_grain {
  fact_finland_economic_health.year_id
  [unique]
}