{
  "datasets": [
    {
      "name": "supported_overrep_2024",
      "displayName": "Supported Overrepresented 2024",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcy_specialization_lq`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_bankruptcy_specialization` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year` = 2024\n",
        "  AND f.`specialization_support_class` = 'Supported signal'\n",
        "  AND f.`bankruptcy_specialization_lq` > 1\n",
        "ORDER BY\n",
        "  f.`bankruptcy_specialization_lq` DESC"
      ],
      "columns": [
        {
          "displayName": "Municipality — Industry",
          "description": "Combined label for bar chart x-axis showing municipality and industry together.",
          "expression": "CONCAT(`municipality_name`, ' — ', `industry_name`)"
        }
      ]
    },
    {
      "name": "specialization_trend",
      "displayName": "Specialization Trend by Year",
      "queryLines": [
        "SELECT\n",
        "  dy.`year`,\n",
        "  f.`specialization_absolute_class`,\n",
        "  COUNT(*) as combination_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_bankruptcy_specialization` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "WHERE\n",
        "  f.`specialization_support_class` = 'Supported signal'\n",
        "GROUP BY\n",
        "  dy.`year`,\n",
        "  f.`specialization_absolute_class`\n",
        "ORDER BY\n",
        "  dy.`year`"
      ]
    },
    {
      "name": "industry_frequency",
      "displayName": "Industry Overrepresentation Frequency",
      "queryLines": [
        "SELECT\n",
        "  di.`industry_name`,\n",
        "  COUNT(*) as overrepresentation_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_bankruptcy_specialization` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  f.`specialization_support_class` = 'Supported signal'\n",
        "  AND f.`bankruptcy_specialization_lq` > 1\n",
        "GROUP BY\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  overrepresentation_count DESC"
      ]
    },
    {
      "name": "scatter_2024",
      "displayName": "Scatter — Enterprise vs Employee LQ (2024)",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcy_specialization_lq`,\n",
        "  f.`bankruptcy_employee_specialization_lq`,\n",
        "  f.`specialization_support_class`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_bankruptcy_specialization` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year` = 2024\n",
        "  AND f.`specialization_support_class` IN ('Supported signal', 'Thin municipality bankruptcy base')\n",
        "  AND f.`bankruptcy_specialization_lq` > 1\n",
        "ORDER BY\n",
        "  f.`bankruptcy_specialization_lq` DESC"
      ]
    },
    {
      "name": "support_breakdown",
      "displayName": "Support Quality Breakdown",
      "queryLines": [
        "SELECT\n",
        "  f.`specialization_support_class`,\n",
        "  COUNT(*) as row_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_bankruptcy_specialization` f\n",
        "GROUP BY\n",
        "  f.`specialization_support_class`\n",
        "ORDER BY\n",
        "  row_count DESC"
      ]
    },
    {
      "name": "validation_top10",
      "displayName": "Validation — Top 10 All Classes (2024)",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcies_enterprises`,\n",
        "  f.`bankruptcy_specialization_lq`,\n",
        "  f.`bankruptcy_employee_specialization_lq`,\n",
        "  f.`specialization_support_class`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_bankruptcy_specialization` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year` = 2024\n",
        "ORDER BY\n",
        "  f.`bankruptcy_specialization_lq` DESC\n",
        "LIMIT 10"
      ]
    }
  ],
