{
  "datasets": [
    {
      "name": "kpi_latest",
      "displayName": "KPI â€” Latest Year",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_finland_economic_health`\n",
        "WHERE\n",
        "  `year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_finland_economic_health`\n",
        "    )"
      ]
    },
    {
      "name": "all_years",
      "displayName": "All Years â€” Full Data",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_finland_economic_health`\n",
        "ORDER BY\n",
        "  `year`"
      ]
    },
    {
      "name": "growth_data",
      "displayName": "Growth Data (Excl. First Year)",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_finland_economic_health`\n",
        "WHERE\n",
        "  `bankruptcy_growth_pct` IS NOT NULL\n",
        "ORDER BY\n",
        "  `year`"
      ],
      "columns": [
        {
          "displayName": "Growth Direction",
          "description": "Categorizes years as Growth or Contraction based on net new establishments sign.",
          "expression": "CASE WHEN `new_establishments_yoy` >= 0 THEN 'Growth' ELSE 'Contraction' END"
        }
      ]
    }
  ],
