{
  "datasets": [
    {
      "name": "industries_latest",
      "displayName": "Industries â€” Latest Year Aggregates",
      "queryLines": [
        "SELECT\n",
        "  di.`industry_name`,\n",
        "  SUM(f.`bankruptcies_employees`) as total_employees_affected,\n",
        "  AVG(f.`employees_affected_per_bankruptcy`) as avg_employees_per_bankruptcy\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "GROUP BY\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  total_employees_affected DESC"
      ]
    },
    {
      "name": "top5_employees_trend",
      "displayName": "Top 5 Industries â€” Employees Over Time",
      "queryLines": [
        "WITH top5 AS (\n",
        "  SELECT\n",
        "    f.`industry_id`\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "  GROUP BY\n",
        "    f.`industry_id`\n",
        "  ORDER BY\n",
        "    SUM(f.`bankruptcies_employees`) DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  dy.`year`,\n",
        "  di.`industry_name`,\n",
        "  SUM(f.`bankruptcies_employees`) as total_employees_affected\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  f.`industry_id` IN (\n",
        "    SELECT\n",
        "      `industry_id`\n",
        "    FROM\n",
        "      top5\n",
        "  )\n",
        "GROUP BY\n",
        "  dy.`year`,\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  dy.`year`,\n",
        "  total_employees_affected DESC"
      ]
    },
    {
      "name": "industry_year_heatmap",
      "displayName": "Industry Ă— Year Employee Heatmap",
      "queryLines": [
        "SELECT\n",
        "  dy.`year`,\n",
        "  di.`industry_name`,\n",
        "  SUM(f.`bankruptcies_employees`) as total_employees_affected\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "GROUP BY\n",
        "  dy.`year`,\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  di.`industry_name`,\n",
        "  dy.`year`"
      ]
    },
    {
      "name": "impact_class_trend",
      "displayName": "Labor Impact Class Trend",
      "queryLines": [
        "SELECT\n",
        "  dy.`year`,\n",
        "  f.`labor_impact_absolute_class`,\n",
        "  COUNT(*) as combination_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "GROUP BY\n",
        "  dy.`year`,\n",
        "  f.`labor_impact_absolute_class`\n",
        "ORDER BY\n",
        "  dy.`year`"
      ]
    },
    {
      "name": "severe_top20",
      "displayName": "Top 20 Severe Combinations (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcies_employees`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "  AND f.`labor_impact_class` = 'Severe labor impact'\n",
        "ORDER BY\n",
        "  f.`bankruptcies_employees` DESC\n",
        "LIMIT 20"
      ],
      "columns": [
        {
          "displayName": "Municipality â€” Industry",
          "description": "Combined label for bar chart showing municipality and industry together.",
          "expression": "CONCAT(`municipality_name`, ' â€” ', `industry_name`)"
        }
      ]
    },
    {
      "name": "kpi_severe_count",
      "displayName": "KPI â€” Severe Impact Count (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as severe_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_industry_labor_impact_bankruptcies` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "  AND f.`labor_impact_class` = 'Severe labor impact'"
      ]
    }
  ],
