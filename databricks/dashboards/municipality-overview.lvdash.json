{
  "datasets": [
    {
      "name": "latest_year_all",
      "displayName": "Latest Year — All Municipalities",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`population`,\n",
        "  f.`deaths`,\n",
        "  f.`death_rate_per_1000`,\n",
        "  f.`establishments_count`,\n",
        "  f.`personnel_staff_years`,\n",
        "  f.`total_bankruptcies_enterprises`,\n",
        "  f.`total_bankruptcies_employees`,\n",
        "  f.`bankruptcies_per_1000_establishments`,\n",
        "  f.`bankruptcies_per_100k_population`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview`\n",
        "    )"
      ]
    },
    {
      "name": "top20_pressure",
      "displayName": "Top 20 — Bankruptcy Pressure",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`bankruptcies_per_1000_establishments`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview`\n",
        "    )\n",
        "  AND f.`establishments_count` > 0\n",
        "ORDER BY\n",
        "  f.`bankruptcies_per_1000_establishments` DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "top20_pop_rate",
      "displayName": "Top 20 — Population Bankruptcy Rate",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`bankruptcies_per_100k_population`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview`\n",
        "    )\n",
        "  AND f.`population` > 0\n",
        "ORDER BY\n",
        "  f.`bankruptcies_per_100k_population` DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "top20_death_rate",
      "displayName": "Top 20 — Death Rate",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`death_rate_per_1000`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview`\n",
        "    )\n",
        "  AND f.`population` > 0\n",
        "ORDER BY\n",
        "  f.`death_rate_per_1000` DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "top5_trend",
      "displayName": "Top 5 Pressure Trend — All Years",
      "queryLines": [
        "WITH top5 AS (\n",
        "  SELECT\n",
        "    f.`municipality_id`\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview` f\n",
        "  WHERE\n",
        "    f.`year`\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(`year`)\n",
        "        FROM\n",
        "          `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview`\n",
        "      )\n",
        "    AND f.`establishments_count` > 0\n",
        "  ORDER BY\n",
        "    f.`bankruptcies_per_1000_establishments` DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  f.`year`,\n",
        "  dm.`municipality_name`,\n",
        "  f.`bankruptcies_per_1000_establishments`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_overview` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`municipality_id` IN (\n",
        "    SELECT\n",
        "      `municipality_id`\n",
        "    FROM\n",
        "      top5\n",
        "  )\n",
        "ORDER BY\n",
        "  f.`year`,\n",
        "  dm.`municipality_name`"
      ]
    }
  ],
