{
  "datasets": [
    {
      "name": "all_years_composite",
      "displayName": "Resilience Distribution All Years",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fact_economic_shock_exposure\n",
        "WHERE\n",
        "  shock_exposure_composite IS NOT NULL"
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    },
    {
      "name": "heatmap_top20",
      "displayName": "Heatmap Top 20 Bankruptcy CV",
      "queryLines": [
        "WITH top_munis AS (\n",
        "  SELECT\n",
        "    municipality_name\n",
        "  FROM\n",
        "    fact_economic_shock_exposure\n",
        "  WHERE\n",
        "    bankruptcy_rate_cv_3y IS NOT NULL\n",
        "  GROUP BY\n",
        "    municipality_name\n",
        "  ORDER BY\n",
        "    AVG(bankruptcy_rate_cv_3y) DESC\n",
        "  LIMIT 20\n",
        ")\n",
        "SELECT\n",
        "  f.*\n",
        "FROM\n",
        "  fact_economic_shock_exposure f\n",
        "    INNER JOIN top_munis t\n",
        "      ON f.municipality_name = t.municipality_name\n",
        "WHERE\n",
        "  f.bankruptcy_rate_cv_3y IS NOT NULL"
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    },
    {
      "name": "trend_municipalities",
      "displayName": "Municipality Trend",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fact_economic_shock_exposure\n",
        "WHERE\n",
        "  shock_exposure_composite IS NOT NULL\n",
        "  AND array_contains(:municipality_names, municipality_name)"
      ],
      "parameters": [
        {
          "displayName": "Municipality Names",
          "keyword": "municipality_names",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "Rautavaara"
                },
                {
                  "value": "Urjala"
                },
                {
                  "value": "Halsua"
                },
                {
                  "value": "Orivesi"
                },
                {
                  "value": "Merijärvi"
                }
              ]
            }
          }
        }
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    },
    {
      "name": "latest_year_composite",
      "displayName": "Latest Year Composite",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fact_economic_shock_exposure\n",
        "WHERE\n",
        "  year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        fact_economic_shock_exposure\n",
        "    )\n",
        "  AND shock_exposure_composite IS NOT NULL"
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    },
    {
      "name": "top_bottom_15",
      "displayName": "Top & Bottom 15 by Exposure",
      "queryLines": [
        "WITH latest AS (\n",
        "  SELECT\n",
        "    *,\n",
        "    ROW_NUMBER() OVER (ORDER BY shock_exposure_composite DESC) as rank_high,\n",
        "    ROW_NUMBER() OVER (ORDER BY shock_exposure_composite ASC) as rank_low\n",
        "  FROM\n",
        "    fact_economic_shock_exposure\n",
        "  WHERE\n",
        "    year\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(year)\n",
        "        FROM\n",
        "          fact_economic_shock_exposure\n",
        "      )\n",
        "    AND shock_exposure_composite IS NOT NULL\n",
        ")\n",
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  latest\n",
        "WHERE\n",
        "  rank_high <= 15\n",
        "  OR rank_low <= 15"
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    },
    {
      "name": "cv_breakdown",
      "displayName": "CV Breakdown Crisis-prone",
      "queryLines": [
        "SELECT\n",
        "  component,\n",
        "  avg_cv\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      AVG(bankruptcy_rate_cv_3y) as `Bankruptcy Rate (35%)`,\n",
        "      AVG(employee_impact_cv_3y) as `Employee Impact (25%)`,\n",
        "      AVG(business_churn_cv_3y) as `Business Churn (20%)`,\n",
        "      AVG(personnel_cv_3y) as `Personnel (10%)`,\n",
        "      AVG(demographic_stability_cv_3y) as `Demographic Stability (10%)`\n",
        "    FROM\n",
        "      fact_economic_shock_exposure\n",
        "    WHERE\n",
        "      year\n",
        "        = (\n",
        "          SELECT\n",
        "            MAX(year)\n",
        "          FROM\n",
        "            fact_economic_shock_exposure\n",
        "        )\n",
        "      AND shock_resilience_class = 'Crisis-prone'\n",
        "  )\n",
        "    UNPIVOT (\n",
        "      avg_cv FOR component IN (\n",
        "        `Bankruptcy Rate (35%)`,\n",
        "        `Employee Impact (25%)`,\n",
        "        `Business Churn (20%)`,\n",
        "        `Personnel (10%)`,\n",
        "        `Demographic Stability (10%)`\n",
        "      )\n",
        "    )"
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    },
    {
      "name": "municipality_lookup",
      "displayName": "Municipality Lookup",
      "queryLines": [
        "SELECT DISTINCT\n",
        "  municipality_name\n",
        "FROM\n",
        "  fact_economic_shock_exposure\n",
        "WHERE\n",
        "  shock_exposure_composite IS NOT NULL\n",
        "ORDER BY\n",
        "  municipality_name"
      ],
      "catalog": "data_academy_fi_06",
      "schema": "andreas_statfin_gold"
    }
  ],
