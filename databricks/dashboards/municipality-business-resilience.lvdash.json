{
  "datasets": [
    {
      "name": "latest_year_data",
      "displayName": "Latest Year — All Municipalities",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`resilience_score`,\n",
        "  f.`municipality_business_class`,\n",
        "  f.`bankruptcies_per_1000_establishments`,\n",
        "  f.`establishments_count`,\n",
        "  f.`top_bankruptcy_industry`,\n",
        "  f.`yoy_bankruptcies_pct`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience`\n",
        "    )\n",
        "  AND f.`resilience_score` IS NOT NULL"
      ]
    },
    {
      "name": "top_bottom_15",
      "displayName": "Top 15 + Bottom 15 by Resilience",
      "queryLines": [
        "WITH ranked AS (\n",
        "  SELECT\n",
        "    dm.`municipality_name`,\n",
        "    f.`resilience_score`,\n",
        "    f.`municipality_business_class`,\n",
        "    ROW_NUMBER() OVER (ORDER BY f.`resilience_score` DESC) as rank_top,\n",
        "    ROW_NUMBER() OVER (ORDER BY f.`resilience_score` ASC) as rank_bottom\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience` f\n",
        "      INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "        ON f.`municipality_id` = dm.`municipality_id`\n",
        "  WHERE\n",
        "    f.`year`\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(`year`)\n",
        "        FROM\n",
        "          `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience`\n",
        "      )\n",
        "    AND f.`resilience_score` IS NOT NULL\n",
        ")\n",
        "SELECT\n",
        "  `municipality_name`,\n",
        "  `resilience_score`,\n",
        "  `municipality_business_class`\n",
        "FROM\n",
        "  ranked\n",
        "WHERE\n",
        "  rank_top <= 15\n",
        "  OR rank_bottom <= 15\n",
        "ORDER BY\n",
        "  `resilience_score` DESC"
      ]
    },
    {
      "name": "class_distribution",
      "displayName": "Business Class Distribution by Year",
      "queryLines": [
        "SELECT\n",
        "  f.`year`,\n",
        "  f.`municipality_business_class`,\n",
        "  COUNT(*) as municipality_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience` f\n",
        "WHERE\n",
        "  f.`municipality_business_class` IS NOT NULL\n",
        "GROUP BY\n",
        "  f.`year`,\n",
        "  f.`municipality_business_class`\n",
        "ORDER BY\n",
        "  f.`year`"
      ]
    },
    {
      "name": "bottom5_trend",
      "displayName": "Bottom 5 Resilience Trend",
      "queryLines": [
        "WITH bottom5 AS (\n",
        "  SELECT\n",
        "    f.`municipality_id`\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience` f\n",
        "  WHERE\n",
        "    f.`year`\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(`year`)\n",
        "        FROM\n",
        "          `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience`\n",
        "      )\n",
        "    AND f.`resilience_score` IS NOT NULL\n",
        "  ORDER BY\n",
        "    f.`resilience_score` ASC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  f.`year`,\n",
        "  dm.`municipality_name`,\n",
        "  f.`resilience_score`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`municipality_id` IN (\n",
        "    SELECT\n",
        "      `municipality_id`\n",
        "    FROM\n",
        "      bottom5\n",
        "  )\n",
        "  AND f.`resilience_score` IS NOT NULL\n",
        "ORDER BY\n",
        "  f.`year`,\n",
        "  dm.`municipality_name`"
      ]
    },
    {
      "name": "yoy_top20",
      "displayName": "YoY Bankruptcy Change — Top 20",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`yoy_bankruptcies_pct`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_municipality_resilience`\n",
        "    )\n",
        "  AND f.`yoy_bankruptcies_pct` IS NOT NULL\n",
        "ORDER BY\n",
        "  f.`yoy_bankruptcies_pct` DESC\n",
        "LIMIT 20"
      ]
    }
  ],
