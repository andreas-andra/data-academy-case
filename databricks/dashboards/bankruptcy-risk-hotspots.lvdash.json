{
  "datasets": [
    {
      "name": "kpi_summary",
      "displayName": "KPI Summary (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  COUNT(\n",
        "    CASE\n",
        "      WHEN f.`hotspot_risk_class` = 'Severe hotspot' THEN 1\n",
        "    END\n",
        "  ) as severe_hotspot_count,\n",
        "  ROUND(AVG(f.`bankruptcies_per_1000_establishments`), 2) as avg_bankruptcy_rate\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )"
      ]
    },
    {
      "name": "kpi_top_municipality",
      "displayName": "Top Municipality (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`bankruptcies_per_1000_establishments`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "ORDER BY\n",
        "  f.`bankruptcies_per_1000_establishments` DESC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "chart_top15",
      "displayName": "Top 15 Municipalities by Bankruptcy Rate",
      "queryLines": [
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  f.`bankruptcies_per_1000_establishments`,\n",
        "  f.`hotspot_risk_class`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "ORDER BY\n",
        "  f.`bankruptcies_per_1000_establishments` DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "chart_risk_dist",
      "displayName": "Absolute Risk Class Distribution by Year",
      "queryLines": [
        "SELECT\n",
        "  dy.`year`,\n",
        "  f.`hotspot_absolute_risk_class`,\n",
        "  COUNT(*) as municipality_count\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "GROUP BY\n",
        "  dy.`year`,\n",
        "  f.`hotspot_absolute_risk_class`\n",
        "ORDER BY\n",
        "  dy.`year`,\n",
        "  f.`hotspot_absolute_risk_class`"
      ]
    },
    {
      "name": "chart_rolling_avg",
      "displayName": "Rolling 3Y Avg — Top 10 Municipalities",
      "queryLines": [
        "WITH top_municipalities AS (\n",
        "  SELECT\n",
        "    f.`municipality_id`\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "      INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "        ON f.`year_id` = dy.`year_id`\n",
        "  WHERE\n",
        "    dy.`year`\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(`year`)\n",
        "        FROM\n",
        "          `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "      )\n",
        "  ORDER BY\n",
        "    f.`bankruptcies_per_1000_establishments` DESC\n",
        "  LIMIT 10\n",
        ")\n",
        "SELECT\n",
        "  dy.`year`,\n",
        "  dm.`municipality_name`,\n",
        "  f.`rolling_3y_avg_bankruptcy_rate`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON f.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON f.`municipality_id` = dm.`municipality_id`\n",
        "WHERE\n",
        "  f.`municipality_id` IN (\n",
        "    SELECT\n",
        "      `municipality_id`\n",
        "    FROM\n",
        "      top_municipalities\n",
        "  )\n",
        "ORDER BY\n",
        "  dy.`year`,\n",
        "  dm.`municipality_name`"
      ]
    },
    {
      "name": "chart_industry_freq",
      "displayName": "Hotspot Industry Frequency",
      "queryLines": [
        "SELECT\n",
        "  di.`industry_name`,\n",
        "  COUNT(*) as frequency\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcy_risk_hotspots` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`hotspot_industry_id` = di.`industry_id`\n",
        "GROUP BY\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  frequency DESC"
      ]
    }
  ],
