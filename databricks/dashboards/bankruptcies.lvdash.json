        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON fb.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON fb.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "  AND di.`industry_name` NOT ILIKE '%total%'\n",
        "  AND di.`industry_name` NOT ILIKE '%unknown%'\n",
        "GROUP BY\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  total_bankruptcies DESC\n",
        "LIMIT 10"
      ]
    },
