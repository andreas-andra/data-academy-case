    {
      "name": "83351b90",
      "displayName": "National Total Bankruptcies Over Time",
      "queryLines": [
        "SELECT\n",
        "  dy.`year`,\n",
        "  SUM(fb.`bankruptcies_enterprises`) as total_bankruptcies\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON fb.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON fb.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  di.`industry_name` NOT ILIKE '%total%'\n",
        "  AND di.`industry_name` NOT ILIKE '%unknown%'\n",
        "GROUP BY\n",
        "  dy.`year`\n",
        "ORDER BY\n",
        "  dy.`year`"
      ]
    },
    {
      "name": "382af987",
      "displayName": "Bankruptcies Over Time for Top 5 Industries",
      "queryLines": [
        "WITH top_industries AS (\n",
        "  SELECT\n",
        "    di.`industry_name`,\n",
        "    SUM(fb.`bankruptcies_enterprises`) as total_bankruptcies\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "      INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "        ON fb.`industry_id` = di.`industry_id`\n",
        "  WHERE\n",
        "    di.`industry_name` NOT ILIKE '%total%'\n",
        "    AND di.`industry_name` NOT ILIKE '%unknown%'\n",
        "  GROUP BY\n",
        "    di.`industry_name`\n",
        "  ORDER BY\n",
        "    total_bankruptcies DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  dy.`year`,\n",
        "  di.`industry_name`,\n",
        "  SUM(fb.`bankruptcies_enterprises`) as total_bankruptcies\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON fb.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON fb.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  di.`industry_name` IN (\n",
        "    SELECT\n",
        "      `industry_name`\n",
        "    FROM\n",
        "      top_industries\n",
        "  )\n",
        "GROUP BY\n",
        "  dy.`year`,\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  dy.`year`,\n",
        "  total_bankruptcies DESC"
      ]
    },
    {
      "name": "b5bcb29b",
      "displayName": "Municipality × Industry Bankruptcies Heatmap (Latest Year)",
      "queryLines": [
        "WITH top_municipalities AS (\n",
        "  SELECT\n",
        "    dm.`municipality_name`,\n",
        "    SUM(fb.`bankruptcies_enterprises`) as total\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "      INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "        ON fb.`year_id` = dy.`year_id`\n",
        "      INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "        ON fb.`municipality_id` = dm.`municipality_id`\n",
        "      INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "        ON fb.`industry_id` = di.`industry_id`\n",
        "  WHERE\n",
        "    dy.`year`\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(`year`)\n",
        "        FROM\n",
        "          `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "      )\n",
        "    AND di.`industry_name` NOT ILIKE '%total%'\n",
        "    AND di.`industry_name` NOT ILIKE '%unknown%'\n",
        "  GROUP BY\n",
        "    dm.`municipality_name`\n",
        "  ORDER BY\n",
        "    total DESC\n",
        "  LIMIT 15\n",
        ")\n",
        "SELECT\n",
        "  dm.`municipality_name`,\n",
        "  di.`industry_name`,\n",
        "  SUM(fb.`bankruptcies_enterprises`) as bankruptcies\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON fb.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_municipality` dm\n",
        "      ON fb.`municipality_id` = dm.`municipality_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON fb.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "  AND dm.`municipality_name` IN (\n",
        "    SELECT\n",
        "      `municipality_name`\n",
        "    FROM\n",
        "      top_municipalities\n",
        "  )\n",
        "  AND di.`industry_name` NOT ILIKE '%total%'\n",
        "  AND di.`industry_name` NOT ILIKE '%unknown%'\n",
        "GROUP BY\n",
        "  dm.`municipality_name`,\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  dm.`municipality_name`,\n",
        "  bankruptcies DESC"
      ]
    },
    {
      "name": "kpi_national_summary",
      "displayName": "National KPI Summary (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  SUM(fb.`bankruptcies_enterprises`) as total_bankruptcies,\n",
        "  SUM(fb.`bankruptcies_employees`) as total_employees_affected,\n",
        "  COUNT(DISTINCT\n",
        "    CASE\n",
        "      WHEN fb.`bankruptcies_enterprises` > 0 THEN fb.`municipality_id`\n",
        "    END\n",
        "  ) as municipalities_with_bankruptcies\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON fb.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON fb.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "  AND di.`industry_name` NOT ILIKE '%total%'\n",
        "  AND di.`industry_name` NOT ILIKE '%unknown%'"
      ]
    },
    {
      "name": "kpi_top_industry",
      "displayName": "Most Affected Industry (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  di.`industry_name`,\n",
        "  SUM(fb.`bankruptcies_enterprises`) as total_bankruptcies\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies` fb\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year` dy\n",
        "      ON fb.`year_id` = dy.`year_id`\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON fb.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  dy.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`dim_year`\n",
        "    )\n",
        "  AND di.`industry_name` NOT ILIKE '%total%'\n",
        "  AND di.`industry_name` NOT ILIKE '%unknown%'\n",
        "GROUP BY\n",
        "  di.`industry_name`\n",
        "ORDER BY\n",
        "  total_bankruptcies DESC\n",
        "LIMIT 1"
      ]
    }
