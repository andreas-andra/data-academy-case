    {
      "name": "top5_rolling_trend",
      "displayName": "Top 5 Rolling Growth Trend",
      "queryLines": [
        "WITH base AS (\n",
        "  SELECT\n",
        "    f.year,\n",
        "    f.municipality_id,\n",
        "    m.municipality_name,\n",
        "    f.establishments_count,\n",
        "    LAG(f.establishments_count) OVER (PARTITION BY f.municipality_id ORDER BY f.year) AS prev_est\n",
        "  FROM\n",
        "    data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "      JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "        ON f.municipality_id = m.municipality_id\n",
        "),\n",
        "with_yoy AS (\n",
        "  SELECT\n",
        "    *,\n",
        "    CASE\n",
        "      WHEN\n",
        "        prev_est IS NOT NULL\n",
        "        AND prev_est > 0\n",
        "      THEN\n",
        "        (establishments_count - prev_est) * 100.0 / prev_est\n",
        "    END AS establishments_yoy_pct\n",
        "  FROM\n",
        "    base\n",
        "),\n",
        "with_rolling AS (\n",
        "  SELECT\n",
        "    *,\n",
        "    AVG(establishments_yoy_pct) OVER (\n",
        "        PARTITION BY municipality_id\n",
        "        ORDER BY year\n",
        "        ROWS BETWEEN 2 PRECEDING AND CURRENT ROW\n",
        "      ) AS rolling_3y_avg_growth_pct,\n",
        "    COUNT(establishments_yoy_pct) OVER (\n",
        "        PARTITION BY municipality_id\n",
        "        ORDER BY year\n",
        "        ROWS BETWEEN 2 PRECEDING AND CURRENT ROW\n",
        "      ) AS window_count\n",
        "  FROM\n",
        "    with_yoy\n",
        "),\n",
        "top5 AS (\n",
        "  SELECT\n",
        "    municipality_id\n",
        "  FROM\n",
        "    with_rolling\n",
        "  WHERE\n",
        "    year\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(year)\n",
        "        FROM\n",
        "          data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "      )\n",
        "    AND window_count >= 3\n",
        "  ORDER BY\n",
        "    rolling_3y_avg_growth_pct DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  r.year,\n",
        "  r.municipality_name,\n",
        "  r.rolling_3y_avg_growth_pct\n",
        "FROM\n",
        "  with_rolling r\n",
        "WHERE\n",
        "  r.municipality_id IN (\n",
        "    SELECT\n",
        "      municipality_id\n",
        "    FROM\n",
        "      top5\n",
        "  )\n",
        "  AND r.window_count >= 3\n",
        "ORDER BY\n",
        "  r.year,\n",
        "  r.rolling_3y_avg_growth_pct DESC"
      ]
    },
    {
      "name": "density_class_dist",
      "displayName": "Business Density Class Distribution",
      "queryLines": [
        "WITH density AS (\n",
        "  SELECT\n",
        "    f.year,\n",
        "    f.municipality_id,\n",
        "    CASE\n",
        "      WHEN f.population > 0 THEN f.establishments_count * 1000.0 / f.population\n",
        "    END AS est_per_1000\n",
        "  FROM\n",
        "    data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "),\n",
        "classified AS (\n",
        "  SELECT\n",
        "    year,\n",
        "    municipality_id,\n",
        "    est_per_1000,\n",
        "    NTILE(4) OVER (PARTITION BY year ORDER BY est_per_1000) AS density_quartile\n",
        "  FROM\n",
        "    density\n",
        "  WHERE\n",
        "    est_per_1000 IS NOT NULL\n",
        ")\n",
        "SELECT\n",
        "  year,\n",
        "  CASE density_quartile\n",
        "    WHEN 4 THEN 'High density'\n",
        "    WHEN 3 THEN 'Above average density'\n",
        "    WHEN 2 THEN 'Below average density'\n",
        "    WHEN 1 THEN 'Low density'\n",
        "  END AS business_density_class,\n",
        "  COUNT(*) AS municipality_count\n",
        "FROM\n",
        "  classified\n",
        "GROUP BY\n",
        "  year,\n",
        "  density_quartile\n",
        "ORDER BY\n",
        "  year,\n",
        "  density_quartile DESC"
      ]
    },
