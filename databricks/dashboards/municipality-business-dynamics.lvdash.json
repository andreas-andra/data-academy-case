        "  FROM\n",
        "    base\n",
        ")\n",
        "SELECT\n",
        "  municipality_name,\n",
        "  establishments_yoy_pct\n",
        "FROM\n",
        "  computed\n",
        "WHERE\n",
        "  year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )\n",
        "  AND establishments_yoy_pct IS NOT NULL\n",
        "ORDER BY\n",
        "  establishments_yoy_pct ASC\n",
        "LIMIT 20"
      ]
    }
