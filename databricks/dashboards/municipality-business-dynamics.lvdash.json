{
  "datasets": [
    {
      "name": "latest_year_all",
      "displayName": "All Municipalities (Latest Year)",
      "queryLines": [
        "WITH base AS (\n",
        "  SELECT\n",
        "    f.year,\n",
        "    f.municipality_id,\n",
        "    m.municipality_name,\n",
        "    f.population,\n",
        "    f.establishments_count,\n",
        "    f.personnel_staff_years,\n",
        "    CASE\n",
        "      WHEN f.population > 0 THEN f.establishments_count * 1000.0 / f.population\n",
        "    END AS establishments_per_1000_population,\n",
        "    LAG(f.establishments_count) OVER (PARTITION BY f.municipality_id ORDER BY f.year) AS prev_est,\n",
        "    LAG(f.population) OVER (PARTITION BY f.municipality_id ORDER BY f.year) AS prev_pop,\n",
        "    LAG(f.personnel_staff_years) OVER (PARTITION BY f.municipality_id ORDER BY f.year) AS prev_pers\n",
        "  FROM\n",
        "    data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "      JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "        ON f.municipality_id = m.municipality_id\n",
        "),\n",
        "computed AS (\n",
        "  SELECT\n",
        "    *,\n",
        "    CASE\n",
        "      WHEN\n",
        "        prev_est IS NOT NULL\n",
        "        AND prev_est > 0\n",
        "      THEN\n",
        "        (establishments_count - prev_est) * 100.0 / prev_est\n",
        "    END AS establishments_yoy_pct,\n",
        "    CASE\n",
        "      WHEN\n",
        "        prev_pop IS NOT NULL\n",
        "        AND prev_pop > 0\n",
        "      THEN\n",
        "        (population - prev_pop) * 100.0 / prev_pop\n",
        "    END AS population_yoy_pct,\n",
        "    CASE\n",
        "      WHEN\n",
        "        prev_pers IS NOT NULL\n",
        "        AND prev_pers > 0\n",
        "      THEN\n",
        "        (personnel_staff_years - prev_pers) * 100.0 / prev_pers\n",
        "    END AS personnel_yoy_pct\n",
        "  FROM\n",
        "    base\n",
        ")\n",
        "SELECT\n",
        "  year,\n",
        "  municipality_name,\n",
        "  population,\n",
        "  establishments_count,\n",
        "  personnel_staff_years,\n",
        "  establishments_per_1000_population,\n",
        "  establishments_yoy_pct,\n",
        "  population_yoy_pct,\n",
        "  personnel_yoy_pct\n",
        "FROM\n",
        "  computed\n",
        "WHERE\n",
        "  year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )"
      ]
    },
