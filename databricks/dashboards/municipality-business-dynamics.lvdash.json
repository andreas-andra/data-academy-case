    {
      "name": "top20_density",
      "displayName": "Top 20 by Establishment Density",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.establishments_count * 1000.0 / NULLIF(f.population, 0) AS establishments_per_1000_population\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )\n",
        "  AND f.population > 0\n",
        "ORDER BY\n",
        "  establishments_per_1000_population DESC\n",
        "LIMIT 20"
      ]
    },
