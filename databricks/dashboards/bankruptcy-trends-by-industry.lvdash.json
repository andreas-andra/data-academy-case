{
  "datasets": [
    {
      "name": "latest_year_all",
      "displayName": "Industries — Latest Year",
      "queryLines": [
        "SELECT\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcies_enterprises`,\n",
        "  f.`bankruptcies_employees`,\n",
        "  f.`share_of_total_pct`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies_by_industry` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  f.`year`\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(`year`)\n",
        "      FROM\n",
        "        `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies_by_industry`\n",
        "    )\n",
        "ORDER BY\n",
        "  f.`bankruptcies_enterprises` DESC"
      ]
    },
    {
      "name": "top5_trends",
      "displayName": "Top 5 Industries — All Years",
      "queryLines": [
        "WITH top5 AS (\n",
        "  SELECT\n",
        "    f.`industry_id`\n",
        "  FROM\n",
        "    `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies_by_industry` f\n",
        "  GROUP BY\n",
        "    f.`industry_id`\n",
        "  ORDER BY\n",
        "    SUM(f.`bankruptcies_enterprises`) DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  f.`year`,\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcies_enterprises`,\n",
        "  f.`share_of_total_pct`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies_by_industry` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "WHERE\n",
        "  f.`industry_id` IN (\n",
        "    SELECT\n",
        "      `industry_id`\n",
        "    FROM\n",
        "      top5\n",
        "  )\n",
        "ORDER BY\n",
        "  f.`year`,\n",
        "  f.`bankruptcies_enterprises` DESC"
      ]
    },
    {
      "name": "annual_mix",
      "displayName": "All Industries — All Years",
      "queryLines": [
        "SELECT\n",
        "  f.`year`,\n",
        "  di.`industry_name`,\n",
        "  f.`bankruptcies_enterprises`\n",
        "FROM\n",
        "  `data_academy_fi_06`.`andreas_statfin_gold`.`fact_bankruptcies_by_industry` f\n",
        "    INNER JOIN `data_academy_fi_06`.`andreas_statfin_gold`.`dim_industry` di\n",
        "      ON f.`industry_id` = di.`industry_id`\n",
        "ORDER BY\n",
        "  f.`year`,\n",
        "  f.`bankruptcies_enterprises` DESC"
      ]
    }
  ],
