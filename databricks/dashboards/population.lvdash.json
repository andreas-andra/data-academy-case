{
  "datasets": [
    {
      "name": "top20_population",
      "displayName": "Top 20 by Population",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.population\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )\n",
        "ORDER BY\n",
        "  f.population DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "latest_year_all",
      "displayName": "All Municipalities (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  f.year,\n",
        "  m.municipality_name,\n",
        "  f.population,\n",
        "  f.establishments_count,\n",
        "  f.personnel_staff_years\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )"
      ]
    },
    {
      "name": "top20_establishments",
      "displayName": "Top 20 by Establishments",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.establishments_count\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )\n",
        "ORDER BY\n",
        "  f.establishments_count DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "national_trends",
      "displayName": "National Trends by Year",
      "queryLines": [
        "SELECT\n",
        "  f.year,\n",
        "  SUM(f.population) AS total_population,\n",
        "  SUM(f.establishments_count) AS total_establishments,\n",
        "  SUM(f.personnel_staff_years) AS total_personnel\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "GROUP BY\n",
        "  f.year\n",
        "ORDER BY\n",
        "  f.year"
      ]
    },
    {
      "name": "top20_personnel",
      "displayName": "Top 20 by Personnel",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.personnel_staff_years\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_population f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_population\n",
        "    )\n",
        "ORDER BY\n",
        "  f.personnel_staff_years DESC\n",
        "LIMIT 20"
      ]
    }
  ],
