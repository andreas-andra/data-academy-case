{
  "datasets": [
    {
      "name": "bottom20_pop_change",
      "displayName": "Bottom 20 by Population Change",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.population_change_pct\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "    )\n",
        "  AND f.population_change_pct IS NOT NULL\n",
        "ORDER BY\n",
        "  f.population_change_pct ASC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "top20_death_rate",
      "displayName": "Top 20 by Death Rate",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.death_rate_per_1000\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "    )\n",
        "  AND f.population > 0\n",
        "ORDER BY\n",
        "  f.death_rate_per_1000 DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "kpi_highest_death",
      "displayName": "Highest Death Rate Municipality",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.death_rate_per_1000\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "    )\n",
        "ORDER BY\n",
        "  f.death_rate_per_1000 DESC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "latest_year_all",
      "displayName": "All Municipalities (Latest Year)",
      "queryLines": [
        "SELECT\n",
        "  f.year,\n",
        "  m.municipality_name,\n",
        "  f.population,\n",
        "  f.deaths,\n",
        "  f.population_change_yoy,\n",
        "  f.population_change_pct,\n",
        "  f.death_rate_per_1000\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "    )"
      ]
    },
    {
      "name": "kpi_fastest_decline",
      "displayName": "Fastest Declining Municipality",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.population_change_pct\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.year\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year)\n",
        "      FROM\n",
        "        data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "    )\n",
        "  AND f.population_change_pct IS NOT NULL\n",
        "ORDER BY\n",
        "  f.population_change_pct ASC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "top5_decline_trend",
      "displayName": "Top 5 Decline Trend",
      "queryLines": [
        "WITH top5 AS (\n",
        "  SELECT\n",
        "    f.municipality_id\n",
        "  FROM\n",
        "    data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "  WHERE\n",
        "    f.year\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(year)\n",
        "        FROM\n",
        "          data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "      )\n",
        "    AND f.population_change_pct IS NOT NULL\n",
        "  ORDER BY\n",
        "    f.population_change_pct ASC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  f.year,\n",
        "  m.municipality_name,\n",
        "  f.population_change_pct\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.municipality_id IN (\n",
        "    SELECT\n",
        "      municipality_id\n",
        "    FROM\n",
        "      top5\n",
        "  )\n",
        "  AND f.population_change_pct IS NOT NULL\n",
        "ORDER BY\n",
        "  f.year,\n",
        "  f.population_change_pct ASC"
      ]
    },
    {
      "name": "top5_death_trend",
      "displayName": "Top 5 Death Rate Trend",
      "queryLines": [
        "WITH top5 AS (\n",
        "  SELECT\n",
        "    f.municipality_id\n",
        "  FROM\n",
        "    data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "  WHERE\n",
        "    f.year\n",
        "      = (\n",
        "        SELECT\n",
        "          MAX(year)\n",
        "        FROM\n",
        "          data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality\n",
        "      )\n",
        "  ORDER BY\n",
        "    f.death_rate_per_1000 DESC\n",
        "  LIMIT 5\n",
        ")\n",
        "SELECT\n",
        "  f.year,\n",
        "  m.municipality_name,\n",
        "  f.death_rate_per_1000\n",
        "FROM\n",
        "  data_academy_fi_06.andreas_statfin_gold.fact_regional_mortality f\n",
        "    JOIN data_academy_fi_06.andreas_statfin_gold.dim_municipality m\n",
        "      ON f.municipality_id = m.municipality_id\n",
        "WHERE\n",
        "  f.municipality_id IN (\n",
        "    SELECT\n",
        "      municipality_id\n",
        "    FROM\n",
        "      top5\n",
        "  )\n",
        "ORDER BY\n",
        "  f.year,\n",
        "  f.death_rate_per_1000 DESC"
      ]
    },
    {
      "name": "top20_pop_growth",
      "displayName": "Top 20 by Population Growth",
      "queryLines": [
        "SELECT\n",
        "  m.municipality_name,\n",
        "  f.population_change_pct\n",
